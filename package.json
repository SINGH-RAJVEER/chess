{
	"name": "chess-monorepo",
	"private": true,
	"packageManager": "bun@1.2.22",
	"workspaces": [
		"apps/api",
		"apps/web",
		"apps/engine",
		"packages/types",
		"packages/db"
	],
	"scripts": {
		"lockfile:generate": "bun install --lockfile-only",
		"dev": "turbo run dev --parallel --ui=tui",
		"build": "turbo run build",
		"test": "turbo run test",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"check": "turbo run check",
		"typecheck": "turbo run typecheck",
		"db:generate": "bun --cwd packages/db run db:generate",
		"db:migrate": "bun --cwd packages/db run db:migrate",
		"db:studio": "bun --cwd packages/db run db:studio",
		"clean": "turbo run clean"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"turbo": "^2.5.6"
	}
}
