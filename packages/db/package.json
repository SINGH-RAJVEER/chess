	"exports": {
		".": "./src/index.ts",
		"./config": "./src/config.ts",
		"./schema": "./src/schema.ts"
	},
	"dependencies": {
		"@chess/types": "workspace:*",
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.8"
	},
	"devDependencies": {
		"dotenv": "^17.2.3",
		"drizzle-kit": "^0.31.10"
	}
}
